# Copia este archivo a .env y cambia los valores.
# SECRET_KEY es OBLIGATORIA: la app no arranca con el placeholder ni vacía.
# Genera una con:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-cadena-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite (por defecto, cero configuración):
DATABASE_URL=sqlite:///./chat.db

# Para PostgreSQL (cuando quieras pasar a algo más serio):
# DATABASE_URL=postgresql+psycopg://usuario:password@localhost:5432/chatdb

# --- Adjuntos ---
# Tamaño máximo por archivo subido, en MB (subida en streaming a disco).
# Si usas Caddy, sube también request_body.max_size en deploy/Caddyfile.
MAX_UPLOAD_MB=2048

# --- GIFs (Giphy) ---
# API key gratuita: developers.giphy.com > Create an App > tipo "API" (al
# instante, sin Google Cloud ni tarjeta). Sin ella, el buscador de GIFs queda
# deshabilitado (el resto del chat funciona igual).
GIPHY_API_KEY=

# --- Registro por invitación ---
# Lista de emails (separados por comas) que pueden registrarse. VACÍO = registro
# ABIERTO (cualquiera puede crear cuenta). Con uno o más, SOLO esos correos.
# Las cuentas ya creadas no se ven afectadas. Ej:
#   ALLOWED_EMAILS=ana@gmail.com,luis@gmail.com,pedro@gmail.com
ALLOWED_EMAILS=

# --- Correo (verificación de cuenta) ---
# Gmail: crea una "contraseña de aplicación" en tu cuenta de Google
# (Seguridad > Verificación en 2 pasos > Contraseñas de aplicaciones) y ponla
# en SMTP_PASSWORD; tu dirección en SMTP_USER. Sin SMTP, el código solo se
# escribe en el log del servidor (sirve para probar en local).
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Kurug

# --- LiveKit (voz/pantalla) ---
# URL que reciben los NAVEGADORES para conectarse al SFU. En desarrollo es
# ws://localhost:7880. En producción debe ser wss:// y del mismo origen que la
# app (un reverse proxy enruta /rtc -> LiveKit). Ej: wss://kurug.tudominio.com
LIVEKIT_URL=ws://localhost:7880
# Claves de la API de LiveKit. En dev son devkey/secret; en PRODUCCIÓN genera
# unas propias y ponlas también en deploy/livekit.yaml.
#   API secret: python3 -c "import secrets; print(secrets.token_hex(32))"
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
