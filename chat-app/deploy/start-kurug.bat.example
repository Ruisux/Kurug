@echo off
REM Arranca toda la pila de Kurug en Windows (cada parte en su ventana).
REM COPIA este archivo a  start-kurug.bat  y rellena los secretos.
REM El  start-kurug.bat  con los secretos NO se sube a git (esta en .gitignore).
set KURUG_DIR=C:\kurug\chat-app
set MAGICDNS=kurug.duckdns.org
REM El bot necesita el MISMO SECRET_KEY que el backend (.env):
set BOT_SECRET=PEGA_AQUI_EL_MISMO_SECRET_KEY
REM Clave/secret de LiveKit (deben coincidir con deploy\livekit.yaml):
set LK_API_KEY=kurug
set LK_SECRET=PEGA_AQUI_EL_SECRET_DE_LIVEKIT

REM 1) LiveKit (voz/pantalla)
start "Kurug LiveKit" cmd /k "cd /d %KURUG_DIR% && livekit-server --config deploy\livekit.yaml"

REM 2) Backend (un solo worker)
start "Kurug Backend" cmd /k "cd /d %KURUG_DIR% && .venv\Scripts\python -m uvicorn app.main:app --host 127.0.0.1 --port 8000"

REM 3) Bot de musica
start "Kurug Bot" cmd /k "cd /d %KURUG_DIR%\bot && set SECRET_KEY=%BOT_SECRET% && set LIVEKIT_URL=ws://localhost:7880 && set LIVEKIT_API_KEY=%LK_API_KEY% && set LIVEKIT_API_SECRET=%LK_SECRET% && .venv\Scripts\python bot.py"

REM 4) Caddy (HTTPS / reverse proxy)
start "Kurug Caddy" cmd /k "cd /d %KURUG_DIR% && caddy run --config deploy\Caddyfile-windows"

echo Kurug arrancado. Entra en https://%MAGICDNS%
