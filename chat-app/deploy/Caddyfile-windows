# Caddy en Windows con dominio DuckDNS + HTTPS automático (Let's Encrypt).
# Une en UN origen (https://kurug.duckdns.org): la SPA, la API y la
# señalización de LiveKit. Ejecuta:  caddy run --config deploy\Caddyfile-windows
#
# Requisitos:
#   - Tener creado kurug.duckdns.org y que apunte a tu IP pública (el
#     actualizador de DuckDNS la mantiene al día).
#   - Reenviar en el router al PC:  TCP 80 y TCP 443 (Caddy saca el cert por el 80).
#
# Sustituye "kurug.duckdns.org" y la ruta de  root *  por tu carpeta dist.
#
# Usa bloques `handle` (exclusivos) para que el `try_files` de la SPA NO reescriba
# las rutas de API (/channels, /users, ...) a /index.html antes del reverse_proxy.

kurug.duckdns.org {
    # Caddy obtiene y renueva el certificado automáticamente (Let's Encrypt).

    # Cabeceras de seguridad (se aplican a todas las respuestas).
    header {
        # Fuerza HTTPS en el navegador durante 1 año (evita downgrade a http).
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # El navegador no "adivina" tipos MIME (evita algunos XSS).
        X-Content-Type-Options "nosniff"
        # Nadie puede embeber la app en un iframe (anti-clickjacking).
        X-Frame-Options "DENY"
        # No filtrar la URL completa como referer a otros sitios.
        Referrer-Policy "strict-origin-when-cross-origin"
        # Oculta la cabecera Server (menos info al atacante).
        -Server
    }

    # Subidas grandes (acorde con MAX_UPLOAD_MB).
    request_body {
        max_size 2GB
    }

    # Señalización de LiveKit -> SFU.
    @livekit path /rtc* /twirp*
    handle @livekit {
        reverse_proxy 127.0.0.1:7880
    }

    # API REST + WebSockets de la app -> backend.
    @backend path /auth* /users* /channels* /presence* /dms* /voice* /uploads* /gifs* /static* /ws*
    handle @backend {
        reverse_proxy 127.0.0.1:8000
    }

    # El resto: la SPA estática (build de web/dist), con fallback a index.html.
    handle {
        root * C:\kurug\chat-app\web\dist
        try_files {path} /index.html
        file_server
    }
}
