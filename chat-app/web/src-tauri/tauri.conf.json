{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kurug",
  "version": "0.1.1",
  "identifier": "com.kurug.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Kurug",
        "width": 1200,
        "height": 800,
        "minWidth": 760,
        "minHeight": 520,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Ruisux/Kurug/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2QkZERjc3OTM3QzgzNTIKUldSU2czeVRkOSsvNWxDZWNFcVVSWW05UTNtbmErcjlJQTNXeVA1b0k2ZmtCdWpQcnd2YlNBZlYK"
    }
  }
}
